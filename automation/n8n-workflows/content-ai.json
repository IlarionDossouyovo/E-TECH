    {"parameters": {"prompt": "Translate this to English: {{$json.article_fr}}", "id": "translate", "name": "Translate EN", "type": "anthropic", "position": [300, 450]},
    {"parameters": {"operation": "append", "sheetId": "{{$credentials.google_sheets_id}}", "range": "Content_Calendar!A1", "value": "{{$json.article}}"}, "id": "save", "name": "Save to Sheets", "type": "googleSheets", "position": [500, 300]},
